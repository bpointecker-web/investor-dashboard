# ============================================================================
# Investor Dashboard - Konfiguration
# Kopiere diese Datei nach `.env` und trage deinen FRED-API-Key ein.
# ============================================================================

# ---- Pflicht ----------------------------------------------------------------
# Kostenloser FRED API Key: https://fred.stlouisfed.org/docs/api/api_key.html
# Ohne diesen Key startet das Dashboard nicht (Fail-Fast).
FRED_API_KEY=

# ---- Optional ---------------------------------------------------------------
# CoinGecko Free-Tier funktioniert ohne Key. Demo-/Pro-Key optional eintragbar.
# COINGECKO_API_KEY=

# Server
# DASHBOARD_HOST=127.0.0.1
# DASHBOARD_PORT=8000

# Logging: DEBUG | INFO | WARNING | ERROR  (default INFO)
# LOG_LEVEL=INFO
# LOG_JSON=false   # true => JSON-Logs (Prod), false => key=value (Dev)

# Historie & Cache
# HISTORY_YEARS=10
# DEFAULT_CACHE_TTL_MINUTES=60
# HTTP_TIMEOUT_SECONDS=10

# Quellen-URLs (selten noetig; Shiller/NAAIM verschieben ihre Dateien gelegentlich)
# SHILLER_XLS_URL=https://img1.wsimg.com/blobby/go/.../ie_data.xls
# NAAIM_XLS_URL=https://naaim.org/wp-content/uploads/.../NAAIM-Exposure-Index-Data.xls
